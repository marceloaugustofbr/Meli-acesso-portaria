{
  "name": "react-firebase-admin",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@hookform/resolvers": "^2.9.11",
    "@tanstack/react-query": "^4.36.1",
    "bulma": "^0.9.4",
    "classnames": "^2.3.2",
    "firebase": "^9.23.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "prop-types": "^15.8.1",
    "qrcode.react": "^4.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-hook-form": "^7.49.3",
    "react-router-dom": "^5.3.4",
    "react-scripts": "5.0.1",
    "react-signature-canvas": "^1.0.6",
    "recharts": "^2.10.3",
    "sass": "^1.69.5",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "scripts": {
    "start": "cross-env GENERATE_SOURCEMAP=false react-scripts start",
    "build": "cross-env GENERATE_SOURCEMAP=false react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint .",
    "setup-admin-dashboard": "npm install && npm run build && firebase deploy",
    "deploy": "npm run build && firebase deploy --only hosting",
    "precommit:react": "npm test",
    "precommit:functions": "cd functions/ && npm run build && npm test",
    "precommit": "cross-env CI=true npm run precommit:react && npm run precommit:functions"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.6",
    "@testing-library/react": "^11.2.2",
    "babel-eslint": "^10.1.0",
    "cross-env": "^10.1.0",
    "deep-freeze": "^0.0.1",
    "dotenv": "^8.2.0",
    "eslint": "^7.15.0",
    "eslint-config-airbnb": "^18.2.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-loader": "^4.0.2",
    "eslint-plugin-import": "^2.21.2",
    "eslint-plugin-jest": "^23.18.0",
    "eslint-plugin-jsx-a11y": "^6.3.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.20.5",
    "husky": "^4.3.5",
    "lint-staged": "^10.5.3",
    "prettier": "^2.2.1",
    "sass-loader": "^10.1.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit && lint-staged"
    }
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}"
    ],
    "coverageReporters": [
      "text",
      "html"
    ],
    "resetMocks": true
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "functions/**/*.ts": [
      "npm run lint"
    ]
  }
}
