rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Regras restritas ──────────────────────
    // TODO: Após deploy do Worker, remover accessos diretos do cliente
    // O Worker usa Admin SDK (service account) que ignora estas regras

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    // Config: só Worker (via Firebase Auth ID token com isAdmin) pode ler/escrever
    match /config/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Users: cada um vê seu próprio perfil; admins veem tudo
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow read: if isOwner() || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // Latest exams: apenas Worker (admin)
    match /latest_exams/{cpf} {
      allow read: if isAdmin();
      allow write, create, delete: if isAdmin();
    }

    // Aggregations: apenas Worker (admin)
    match /aggregations/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Exam UIDs: apenas Worker (admin)
    match /exam_uids/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Questions: Worker (isAdmin) leva as questoes, clientes nao tem acesso direto
    match /questions/{questionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
