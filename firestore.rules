rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow read: if isAuthenticated() && (isAdmin() || isOwner());
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'role', 'claims']))
      );
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /latest_exams/{cpf} {
      allow get: if request.auth == null || isAuthenticated();
      allow list: if isAuthenticated();
      allow create, update: if request.auth == null || isAuthenticated();
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /aggregations/{docId} {
      allow read: if isAuthenticated();
      allow write: if request.auth == null || isAuthenticated();
    }

    match /questions/{questionId} {
      allow read: if request.auth == null || isAuthenticated();
      allow write: if request.auth == null || isAuthenticated();
    }
  }
}
